# =============================================================================
# Supabase — variáveis de ambiente do frontend
# -----------------------------------------------------------------------------
# Copie este arquivo para `.env.local` e preencha com as credenciais do seu
# projeto Supabase (Project Settings -> API).
#
# IMPORTANTE: no Vite, somente variáveis prefixadas com VITE_ são expostas ao
# código do cliente. NUNCA coloque a `service_role key` aqui — apenas a chave
# pública `anon`, que é segura para uso no navegador quando o RLS está ativo.
# =============================================================================

VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-chave-anon-publica
